generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExpenseCategory {
  Food
  Transportation
  Entertainment
  Utilities
  Healthcare
  Other
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())

  expenses Expense[]
  incomes  Income[]
}

model Expense {
  id        String          @id @default(uuid())
  amount    Float
  category  ExpenseCategory
  note      String?
  date      DateTime
  createdAt DateTime        @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
}

model Income {
  id        String   @id @default(uuid())
  amount    Float
  source    String
  note      String?
  date      DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
